{
  "name": "skymarkwebsite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host\" \"npm run sass\"",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "sass": "npm run compile:sass && concurrently \"sass --watch --poll --no-source-map sass/main.scss:styles/sassStyle.css\" \"npm run prefix:css\" \"npm run compress:css\" \"npm run concat:css\"",
    "compile:sass": "sass sass/main.scss styles/sassStyle.css",
    "compress:css": "sass styles/sassStyle.css styles/sassStyle.prefix.css --style=compressed",
    "concat:css": "concat -o styles/style.concated.css styles/icon-font.css styles/sassStyle.css",
    "prefix:css": "postcss styles/sassStyle.css --use autoprefixer -o styles/sassStyle.prefixed.css"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "framer-motion": "^12.4.3",
    "locomotive-scroll": "^4.1.4",
    "motion": "^11.15.0",
    "react": "^18.3.1",
    "react-countup": "^6.5.3",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.5.1",
    "react-icons": "^5.4.0",
    "react-intersection-observer": "^9.15.1",
    "react-locomotive-scroll": "^0.2.2",
    "react-responsive": "^10.0.0",
    "react-router-dom": "^7.1.1",
    "react-slick": "^0.30.3",
    "sass": "^1.83.0",
    "simple-react-validator": "^1.6.2",
    "slick-carousel": "^1.8.1",
    "swiper": "^11.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concat-cli": "^4.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^9.17.0",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "postcss": "^8.5.3",
    "postcss-cli": "^11.0.0",
    "vite": "^6.0.5"
  }
}
